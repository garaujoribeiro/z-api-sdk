{
  "name": "z-api-sdk",
  "version": "0.0.1",
  "description": "Typed TypeScript SDK for the Z-API WhatsApp API, with an ergonomic resource-oriented client.",
  "keywords": [
    "z-api",
    "zapi",
    "whatsapp",
    "whatsapp-api",
    "sdk",
    "typescript",
    "client"
  ],
  "license": "MIT",
  "author": "Gabriel Ribeiro <gabriel.ribeiro@grupovorp.com>",
  "homepage": "https://github.com/garaujoribeiro/z-api-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/garaujoribeiro/z-api-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/garaujoribeiro/z-api-sdk/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "USAGE.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "msw": "^2.7.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
